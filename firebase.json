{
  "hosting": {
    "public": "dist/client",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api-match/**",
        "destination": "https://www.cricbuzz.com"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
